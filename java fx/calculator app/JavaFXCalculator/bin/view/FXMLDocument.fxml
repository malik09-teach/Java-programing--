<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="application.FXMLDocumentController"
      spacing="10">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <TextField fx:id="display" editable="false" styleClass="display"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
        </columnConstraints>

        <!-- Row 1 -->
        <Button text="7" onAction="#handleNumberAction" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Button text="8" onAction="#handleNumberAction" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Button text="9" onAction="#handleNumberAction" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <Button text="÷" onAction="#handleOperatorAction" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <!-- Row 2 -->
        <Button text="4" onAction="#handleNumberAction" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Button text="5" onAction="#handleNumberAction" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Button text="6" onAction="#handleNumberAction" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <Button text="×" onAction="#handleOperatorAction" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <!-- Row 3 -->
        <Button text="1" onAction="#handleNumberAction" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Button text="2" onAction="#handleNumberAction" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Button text="3" onAction="#handleNumberAction" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <Button text="-" onAction="#handleOperatorAction" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <!-- Row 4 -->
        <Button text="0" onAction="#handleNumberAction" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Button text="C" onAction="#handleClear" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Button text="=" onAction="#handleOperatorAction" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <Button text="+" onAction="#handleOperatorAction" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
    </GridPane>
</VBox>
